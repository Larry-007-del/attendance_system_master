# ============================================
# Exodus Attendance System — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# All variables with defaults can be omitted for local development.

# ---- Django Core ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# Uses SQLite by default; set DATABASE_URL for PostgreSQL in production
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ---- Cloudinary (media uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email (SMTP) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ---- SMS — Twilio ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- SMS — Africa's Talking ----
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=

# ---- CORS (production) ----
# Comma-separated origins, e.g. https://your-app.onrender.com
CORS_ALLOWED_ORIGINS=

# ---- Sentry (error tracking) ----
SENTRY_DSN=

# ---- Render (set automatically by Render) ----
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# ---- Cache (optional, defaults to LocMemCache) ----
# For multi-worker production, use database cache:
# CACHE_BACKEND=django.core.cache.backends.db.DatabaseCache
# CACHE_LOCATION=django_cache
