{
  "name": "attendance_system_master",
  "version": "1.0.0",
  "description": "",
  "main": "postcss.config.js",
  "scripts": {
    "build:css": "tailwindcss -i static/css/tailwind.css -o static/css/styles.css --minify",
    "build:js": "node scripts/copy-assets.js",
    "build": "npm run build:css && npm run build:js",
    "watch": "tailwindcss -i static/css/tailwind.css -o static/css/styles.css --watch",
    "dev:server": "python manage.py runserver 0.0.0.0:8000",
    "dev:tailwind": "npm run watch",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:tailwind\"",
    "format": "npx prettier --write \"templates/**/*.html\" \"static/css/**/*.css\" \"static/js/**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Larry-007-del/attendance_system_master.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Larry-007-del/attendance_system_master/issues"
  },
  "homepage": "https://github.com/Larry-007-del/attendance_system_master#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "alpinejs": "^3.15.8",
    "flowbite": "^4.0.1",
    "htmx.org": "^2.0.8"
  }
}
